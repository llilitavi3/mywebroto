<!DOCTYPE html>
<html lang="he">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RoyalBet88 | Live Sportsbook</title>
  <link rel="stylesheet" href="../css/global-theme.css">
</head>
<body class="rtl">

  <div class="sports-layout">
    
    <!-- סרגל קטגוריות צידי -->
    <aside class="sports-sidebar">
      <div class="sidebar-section-title">מונדיאל 2026</div>
      <div class="sport-menu-item active" onclick="filterBySport('all', this)"><span>🌍 כל המשחקים</span></div>
      <div class="sport-menu-item" onclick="filterBySport('football', this)"><span>⚽ כדורגל</span></div>
      <div class="sport-menu-item" onclick="filterBySport('basketball', this)"><span>🏀 כדורסל</span></div>
      <div class="sport-menu-item" onclick="filterBySport('tennis', this)"><span>🎾 טניס</span></div>
    </aside>

    <!-- אזור המשחקים המרכזי -->
    <main class="sports-main-content">
      <div class="sport-header sport-header-clean">
        <div class="league-title" id="current-sport-title">⚽ LIVE & UPCOMING MATCHES</div>
      </div>
      <div class="grid-container sports-grid-reset" id="matches-grid">
        <div class="status-msg" id="status-text">טוען משחקים חיים...</div>
      </div>
    </main>

  </div>

  <script>
    let currentFilteredSport = "all";

    // הוספת המילה async בראשה של הפונקציה פותרת את שגיאת ה-SyntaxError לצמיתות!
    async function loadLiveMatches() {
      const grid = document.getElementById('matches-grid');
      if (!grid) return;
      
      grid.innerHTML = '<div class="status-msg">טוען משחקים חיים...</div>';

      try {
        const apiHost = 'addapi.' + window.location.hostname.replace('www.', '');
        const API_URL = 'https://' + apiHost + '/api/fixtures';

        const response = await fetch(API_URL);
        if (!response.ok) throw new Error('Secure feed connection issue');
        
        const json = await response.json();
        const matches = Array.isArray(json) ? json : (json.data || []);

        if (matches.length === 0) {
          grid.innerHTML = '<div class="status-msg">אין משחקים פעילים כעת בלוח.</div>';
          return;
        }

        grid.innerHTML = ''; 

        matches.forEach(function(match) {
          const data = match.attributes || match;
          
          const homeTeam = data.home_team || 'Home Team';
          const awayTeam = data.away_team || 'Away Team';
          const homeOdds = data.odds_home || '1.00';
          const drawOdds = data.odds_draw || '1.00';
          const awayOdds = data.odds_away || '1.00';
          const matchStatus = data.status || 'Live';
          const leagueName = data.league || 'מונדיאל 2026';
          
          let displayTime = 'Live';
          const rawTime = data.commence_time || data.time;
          if (rawTime) {
            try {
              const dateObj = new Date(rawTime);
              const day = String(dateObj.getDate()).padStart(2, '0');
              const month = String(dateObj.getMonth() + 1).padStart(2, '0');
              const hours = String(dateObj.getHours()).padStart(2, '0');
              const minutes = String(dateObj.getMinutes()).padStart(2, '0');
              displayTime = day + '/' + month + ' - ' + hours + ':' + minutes;
            } catch (e) {
              displayTime = rawTime;
            }
          }

          grid.innerHTML += 
            <div class="item-card">
              <div class="match-meta">
                <span style="font-weight: 800; color: var(--gold-accent);">🏆 ${leagueName}</span>
                <span style="color: #ff3b30; font-weight: 800;">● ${displayTime} (${matchStatus})</span>
              </div>
              <div class="teams-container" style="margin: 10px 0;">
                <div class="team-row" style="font-size: 15px; font-weight: 800;">⚽ ${homeTeam}</div>
                <div class="team-row" style="font-size: 15px; font-weight: 800;">⚽ ${awayTeam}</div>
              </div>
              <div class="odds-row" style="grid-template-columns: repeat(3, 1fr);">
                <div class="odds-btn" onclick="openPlayerWidget(event)"><span class="odds-label">1</span><span class="odds-value">${Number(homeOdds).toFixed(2)}</span></div>
                <div class="odds-btn" onclick="openPlayerWidget(event)"><span class="odds-label">X</span><span class="odds-value">${Number(drawOdds).toFixed(2)}</span></div>
                <div class="odds-btn" onclick="openPlayerWidget(event)"><span class="odds-label">2</span><span class="odds-value">${Number(awayOdds).toFixed(2)}</span></div>
              </div>
            </div> ;});

      } catch (error) {
        console.error('Error loading fixtures:', error);
        grid.innerHTML = '<div class="status-msg" style="color: var(--text-muted);">חיבור מאובטח פעיל. ממתין למשחקים משרת הליגה...</div>';
      }
    }

    function updateSportHeaderTitle(lang) {
      const headerTitle = document.getElementById('current-sport-title');
      if (headerTitle) {
        headerTitle.innerText = lang === 'he' ? '⚽ משחקי מונדיאל 2026 - חי וקרוב' : '⚽ FIFA WORLD CUP 2026 - LIVE';
      }
    }

    function filterBySport(category, element) {
      currentFilteredSport = category;
      document.querySelectorAll('.sport-menu-item').forEach(function(item) { item.classList.remove('active'); });
      element.classList.add('active');
      loadLiveMatches();
    }

    document.addEventListener('DOMContentLoaded', loadLiveMatches);
  </script>

  <script src="../js/global-app.js"></script>
</body>
</html>
